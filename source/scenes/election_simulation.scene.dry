@post_election
on-arrival: {!
// set congress proportion to votes
Q.pfjp_r = Q.pfjp_votes;
Q.usp_r = Q.usp_votes;
Q.nfp_r = Q.nfp_votes;
Q.wpb_r = Q.wpb_votes;
Q.other_r = Q.other_votes;

if (Q.cps_formed) {
    Q.cps_r = Q.cps_votes;
}

if (Q.slp_formed) {
    Q.slp_r = Q.slp_votes;
}

if (Q.nsdaaap_formed) {
    Q.nsdaaap_r = Q.nsdaaap_votes;
}

// largest party
Q.largest_party = 'PFJP';

if (Q.usp_r >= Q.pfjp_r) {
    Q.largest_party = 'USP';
}

if (Q.nfp_r >= Q.pfjp_r && Q.nfp_r >= Q.usp_r) {
    Q.largest_party = 'NFP';
}

if (Q.wpb_r >= Q.pfjp_r && Q.wpb_r >= Q.usp_r && Q.wpb_r >= Q.nfp_r) {
    Q.largest_party = 'WPB';
}

if (Q.cps_formed && Q.cps_r >= Q.pfjp_r && Q.cps_r >= Q.usp_r && Q.cps_r >= Q.nfp_r && Q.cps_r >= Q.wpb_r) {
    Q.largest_party = 'CPS';
}

if (Q.slp_formed && Q.slp_r >= Q.pfjp_r && Q.slp_r >= Q.usp_r && Q.slp_r >= Q.nfp_r && Q.slp_r >= Q.wpb_r && Q.slp_r >= Q.cps_r) {
    Q.largest_party = 'SLP';
}

if (Q.nsdaaap_formed && Q.nsdaaap_r >= Q.pfjp_r && Q.nsdaaap_r >= Q.usp_r && Q.nsdaaap_r >= Q.nfp_r && Q.nsdaaap_r >= Q.wpb_r && Q.nsdaaap_r >= Q.cps_r && Q.nsdaaap_r >= Q.slp_r) {
    Q.largest_party = 'NSDAAAP';
}

// coalitions
Q.weimar_coalition = Q.pfjp_r + Q.usp_r;
Q.grand_coalition = Q.pfjp_r + Q.usp_r + Q.nfp_r;
Q.bourgeois_coalition = Q.usp_r + Q.nfp_r + Q.other_r;
Q.center_right_coalition = Q.usp_r + Q.nfp_r + Q.other_r + Q.wpb_r;
Q.right_coalition = Q.usp_r + Q.nfp_r + Q.other_r + Q.wpb_r;
Q.far_right_coalition = Q.wpb_r;

if (Q.nsdaaap_formed) {
    Q.far_right_coalition += Q.nsdaaap_r;
}

Q.left_coalition = Q.pfjp_r;

if (Q.cps_formed) {
    Q.left_coalition += Q.cps_r;
}

Q.united_front_coalition = Q.pfjp_r + Q.usp_r;

if (Q.cps_formed) {
    Q.united_front_coalition += Q.cps_r;
}

if (Q.slp_formed) {
    Q.united_front_coalition += Q.slp_r;
}

Q.anti_democratic_coalition = 0;

if (Q.cps_formed) {
    Q.anti_democratic_coalition += Q.cps_r;
}

if (Q.nsdaaap_formed) {
    Q.anti_democratic_coalition += Q.nsdaaap_r;
}

// aka everyone except CPS, NSDAAAP, and WPB
Q.neo_weimar_coalition = Q.pfjp_r + Q.usp_r + Q.nfp_r + Q.other_r;

if (Q.slp_formed) {
    Q.neo_weimar_coalition += Q.slp_r;
}
!}

The electoral system is essentially proportional, with the proportion of Reichstag seats roughly equal to the proportion of votes.
 
**Election results:**

# 1949: 30, 1953: 20
PFJP: [+ pfjp_r +]

[? if cps_formed and cps_r > 0: CPS: [+ cps_r +] ?]

[? if slp_formed and slp_r > 0: SLP: [+ slp_r +] ?]

# 1949: 34, 1953: 37
USP: [+ usp_r +]

# 1949: 9, 1953: 11
NFP: [+ nfp_r +]

# 1949: 6, 1953: 9
WPB: [+ wpb_r +]

[? if nsdaaap_formed and nsdaaap_r > 0: NSDAAAP: [+ nsdaaap_r +] ?]

# 1949: 21, 1953: 15
Other: [+ other_r +]

**Potential coalitions:**

Weimar Coalition (PFJP + USP): [+ weimar_coalition +]

Grand Coalition (PFJP + USP + NFP): [+ grand_coalition +]

Bourgeois Coalition (USP + NFP + Others): [+ bourgeois_coalition +]

Right-wing Coalition (USP + NFP + Others + WPB): [+ right_coalition +]
