title: Election Simulation
set-jump: post_election


- @1928: 1928 historical scenario
- @1930: 1930 historical scenario
- @1932: 1932 (July) historical scenario

@1928
on-arrival: {!
Q.workers = 46; // industry and trade
Q.old_middle = 13; // "old mittelstand"
// 16.4 trade & commerce, 6.6 public and private services, 4.4 domestic help
Q.new_middle = 14; // "new mittelstand"
Q.rural = 25; // agriculture and forestry employment... but many of those are proletarians so...
// source: https://surface.syr.edu/cgi/viewcontent.cgi?filename=3&article=1016&context=books&type=additional page 43, table 3.3
Q.unemployed = 8.6;
Q.bluds = 30;

Q.classes = ['workers', 'old_middle', 'new_middle', 'rural', 'unemployed', 'bluds'];
Q.parties = ['pfjp', 'usp', 'nfp', 'wpb', 'other'];

if (Q.cps_formed) {
    Q.parties.push('cps');
}

if (Q.slp_formed) {
    Q.parties.push('slp');
}

if (Q.nsdaaap_formed) {
    Q.parties.push('nsdaaap');
}

// Support for party by social group
// they don't have to sum to 100 since the electoral calculations will be normalized.
Q.workers_pfjp = 65;
Q.workers_cps = 0;
Q.workers_slp = 0;
Q.workers_usp = 5;
Q.workers_nfp = 0;
Q.workers_wpb = 5;
Q.workers_nsdaaap = 0;
Q.workers_other = 10;

Q.old_middle_pfjp = 5;
Q.old_middle_cps = 0;
Q.old_middle_slp = 0;
Q.old_middle_usp = 5;
Q.old_middle_nfp = 25;
Q.old_middle_wpb = 25;
Q.old_middle_nsdaaap = 0;
Q.old_middle_other = 10;

Q.new_middle_pfjp = 5;
Q.new_middle_cps = 0;
Q.new_middle_slp = 0;
Q.new_middle_usp = 10;
Q.new_middle_nfp = 25;
Q.new_middle_wpb = 10;
Q.new_middle_nsdaaap = 0;
Q.new_middle_other = 15;

Q.rural_pfjp = 10;
Q.rural_cps = 0;
Q.rural_slp = 0;
Q.rural_usp = 5;
Q.rural_nfp = 15;
Q.rural_wpb = 45;
Q.rural_nsdaaap = 0;
Q.rural_other = 10;

Q.unemployed_pfjp = 25;
Q.unemployed_cps = 0;
Q.unemployed_slp = 0;
Q.unemployed_usp = 1;
Q.unemployed_nfp = 0;
Q.unemployed_wpb = 5;
Q.unemployed_nsdaaap = 0;
Q.unemployed_other = 9;

Q.bluds_pfjp = 15;
Q.bluds_cps = 0;
Q.bluds_slp = 0;
Q.bluds_usp = 50;
Q.bluds_nfp = 5;
Q.bluds_wpb = 5;
Q.bluds_nsdaaap = 0;
Q.bluds_other = 10;
!}
go-to: election_algorithm
set-jump: post_election

